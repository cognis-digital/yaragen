{
  "name": "cognis-${localWorkspaceFolderBasename}",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "bash scripts/setup-ubuntu.sh || pip install -e '.[dev]'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "GitHub.copilot",
        "redhat.vscode-yaml"
      ]
    }
  },
  "forwardPorts": [8000],
  "remoteUser": "vscode"
}
